22:Tb45,{"@context":"https://schema.org","@graph":[{"@type":"Product","@id":"https://xrtgroup.com/products/brent-crude-oil#product","name":"Brent Crude Oil","description":"Brent Crude Oil from North Sea and West African producing regions. 38.3° API, 0.37% sulfur. ICE Brent benchmark at +$1.20/BBL. Minimum 100,000 BBL, CIF/CFR. Bureau Veritas inspection. <4 hour desk response.","sku":"ENE-002","category":"energy","keywords":"Brent crude oil supplier, buy Brent crude, North Sea crude procurement, crude oil CIF ARA, Brent crude trading company, West Africa crude oil","brand":{"@type":"Brand","name":"XRT Group"},"additionalProperty":[{"@type":"PropertyValue","name":"API Gravity","value":"38.3° API"},{"@type":"PropertyValue","name":"Sulfur Content","value":"0.37% max"},{"@type":"PropertyValue","name":"Origin","value":"North Sea / West Africa"},{"@type":"PropertyValue","name":"Benchmark","value":"ICE Brent Dated"},{"@type":"PropertyValue","name":"Min. Volume","value":"100,000 BBL"},{"@type":"PropertyValue","name":"INCOTERMS","value":"CIF / CFR"},{"@type":"PropertyValue","name":"Loading Ports","value":"Sullom Voe, Hound Point, Bonny Terminal"},{"@type":"PropertyValue","name":"Inspection","value":"Bureau Veritas (IP/ASTM)"},{"@type":"PropertyValue","name":"Settlement","value":"LC (UCP 600)"},{"@type":"PropertyValue","name":"Response SLA","value":"<4 business hours"}],"offers":{"@type":"Offer","url":"https://xrtgroup.com/products/brent-crude-oil","availability":"https://schema.org/InStock","priceCurrency":"USD","description":"Negotiated against ICE Brent benchmark. Indicative differential +$1.20/BBL. Minimum 100,000 BBL.","eligibleQuantity":{"@type":"QuantitativeValue","minValue":"100000","unitText":"BBL"},"seller":{"@type":"Organization","name":"XRT Group LLC","url":"https://xrtgroup.com"}}},{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Products","item":"https://xrtgroup.com/products"},{"@type":"ListItem","position":2,"name":"Brent Cr