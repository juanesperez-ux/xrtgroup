24:T4a1,{"@context":"https://schema.org","@type":"Article","headline":"Crude Oil and Refined Fuel Procurement Guide for Industrial Buyers","description":"Learn how to procure crude oil, diesel EN590, Jet A-1 aviation fuel, and industrial fuels at scale. Specifications, supplier qualification, INCOTERMS, and logistics for energy commodity buyers.","datePublished":"2026-07-07","dateModified":"2026-07-07","author":{"@type":"Organization","name":"XRT Group","description":"XRT Group's commodity procurement team covering direct-origin sourcing, trade finance, inspection, logistics, and compliance across global supply chains.","url":"https://xrtgroup.com/about"},"publisher":{"@type":"Organization","name":"XRT Group","logo":{"@type":"ImageObject","url":"https://xrtgroup.com/xrt-mark.svg"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://xrtgroup.com/blog/crude-oil-refined-fuel-procurement-guide"},"keywords":"crude oil procurement, diesel EN590 supplier, jet fuel procurement, Jet A-1 supplier, industrial fuel sourcing, refined petroleum products, energy commodity buyer, bulk fuel purchase","image":"https://xrtgroup.com/images/photo-oil-pumps-dusk.webp","articleSection":"ENERGY"}25:T7ae,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"D2 vs. EN590: What's the Difference?","acceptedAnswer":{"@type":"Answer","text":"\"D2\" is a general designation for Gas Oil / Diesel used in less standardized market contexts. EN590 is the stricter European specification standard. Most reputable industrial buyers and their refineries require EN590 certification with independent inspection."}},{"@type":"Question","name":"What is the minimum order for diesel EN590 procurement?","acceptedAnswer":{"@type":"Answer","text":"Bulk diesel procurement typically starts at 1,000 MT per cargo (approximately 1.18 million liters). Smaller volumes may be accommodated via ISO tank or truck-delivered product depending on location."}},{"@type":"Question","name":"What documentation is required for a crude oil purchase?","acceptedAnswer":{"@type":"Answer","text":"Standard documentation includes: SGS inspection certificate (quantity and quality), Bill of Lading, COO (Certificate of Origin), commercial invoice, packing list, and for some jurisdictions, a phytosanitary or fumigation certificate equivalent for cargo."}},{"@type":"Question","name":"How does XRT Group handle price volatility for energy commodities?","acceptedAnswer":{"@type":"Answer","text":"We structure contracts with pricing mechanisms appropriate to the buyer's risk profile — fixed price for budget-certainty buyers, floating indexed pricing for buyers who want to capture market downturns, and collar structures for those managing both upside and downside risk."}},{"@type":"Question","name":"Does XRT Group handle US domestic fuel distribution?","acceptedAnswer":{"@type":"Answer","text":"Yes. Our logistics infrastructure includes North American truck and rail distribution for diesel and refined products, with particular capability in Alaska and Hawaii — markets that require specialized logistics coordination due to their geographic position."}}]}1b:[["$","$L19",null,{"id":"jsonld-article","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$24"}}],["$","$L19",null,{"id":"jsonld-faq","type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$25"}}],"$L26","$L27"]
